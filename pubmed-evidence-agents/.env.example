# Deploy mode
# "groq"     -> Llama base models via Groq (fast, recommended for dev)
# "hf"       -> medical fine-tunes via Hugging Face Inference API
# "together" -> Together AI serverless models
# "local"    -> local GPU via Hugging Face transformers
DEPLOY_MODE=groq

# API keys
GROQ_API_KEY=
HF_TOKEN=
TOGETHER_API_KEY=
NCBI_API_KEY=

# Optional model overrides
# OPENBIO_MODEL_ID=llama-3.1-8b-instant
# VERIFIER_MODEL_ID=qwen/qwen3.6-27b

# Retrieval tuning
EMBED_CANDIDATE_K=30
BM25_CANDIDATE_K=30
RERANK_TOP_K=12
USE_BM25=1
USE_CROSS_ENCODER=1

# Prompt/request budgets
PICO_INPUT_TOKEN_BUDGET=1800
RAG_CONTEXT_TOKEN_BUDGET=3600
RAG_PASSAGE_TOKEN_BUDGET=260
VERIFY_CONTEXT_TOKEN_BUDGET=3200
VERIFY_PASSAGE_TOKEN_BUDGET=400
GROQ_MAX_REQUEST_BYTES=18000
GROQ_RETRY_ATTEMPTS=6
GROQ_MAX_RETRY_WAIT_SECONDS=120
GROQ_MIN_REQUEST_INTERVAL_SECONDS=1.5
